# Этот файл является примером для запуска проекта в Docker.
# Скопируйте его в .env и заполните своими данными.

# --- Переменные для базы данных Postgres ---
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=vlessbot

# --- ГЛАВНАЯ НАСТРОЙКА ДЛЯ DOCKER ---
# Строка подключения для SQLAlchemy. 
# Важно, чтобы хост был 'db', а не 'localhost' или '127.0.0.1'
DB_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# --- Переменные бота ---
BOT_TOKEN=your_bot_token
ADMIN_IDS=your_telegram_id

# --- Ключи для платежных систем (опционально) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
TELEGRAM_PAYMENT_PROVIDER_TOKEN=

# --- Настройки X-UI (если используются) ---
XUI_API_URL=
XUI_API_USER=
XUI_API_PASSWORD=

# --- Ключ шифрования ---
# Можно сгенерировать командой: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# --- Прочие настройки (опционально) ---
SUPPORT_CHAT_LINK=
VPN_INFO_POST_URL=
PRIVACY_POLICY_URL=
TERMS_OF_SERVICE_URL=
TRIAL_SERVER_ID=
CRYPTO_YEARLY_PRICE_USD=
CRYPTO_BTC_ADDRESS=
CRYPTO_ETH_ADDRESS=
CRYPTO_USDT_TRC20_ADDRESS=
